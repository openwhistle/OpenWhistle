# Required
DATABASE_URL=postgresql+asyncpg://openwhistle:openwhistle@localhost:5432/openwhistle
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-long-random-secret-key-here

# Application
APP_NAME=OpenWhistle
DEMO_MODE=false

# OIDC (optional)
OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SERVER_METADATA_URL=
OIDC_REDIRECT_URI=

# Branding (optional)
BRAND_PRIMARY_COLOR=#0f4c81
BRAND_SECONDARY_COLOR=#00a878
BRAND_LOGO_URL=

# Production database credentials (for docker-compose.prod.yml)
POSTGRES_USER=openwhistle
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
