# OpenWhistle environment — managed by Ansible, do not edit manually
# Generated: {{ ansible_date_time.iso8601 }}

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://{{ openwhistle_db_user }}:{{ openwhistle_db_password }}@db:5432/{{ openwhistle_db_name }}
POSTGRES_USER={{ openwhistle_db_user }}
POSTGRES_PASSWORD={{ openwhistle_db_password }}
POSTGRES_DB={{ openwhistle_db_name }}

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:{{ openwhistle_redis_password }}@redis:6379/0
REDIS_PASSWORD={{ openwhistle_redis_password }}

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY={{ openwhistle_secret_key }}

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME={{ openwhistle_app_name }}
APP_PUBLIC_URL={{ openwhistle_app_public_url }}
DEMO_MODE={{ openwhistle_demo_mode }}
SUBMISSION_MODE_ENABLED={{ openwhistle_submission_mode_enabled }}
LOG_LEVEL={{ openwhistle_log_level }}
LOG_FORMAT={{ openwhistle_log_format }}

# ── Branding ──────────────────────────────────────────────────────────────────
BRAND_PRIMARY_COLOR={{ openwhistle_brand_primary_color }}
BRAND_SECONDARY_COLOR={{ openwhistle_brand_secondary_color }}
BRAND_LOGO_URL={{ openwhistle_brand_logo_url }}

# ── OIDC ──────────────────────────────────────────────────────────────────────
OIDC_ENABLED={{ openwhistle_oidc_enabled }}
OIDC_CLIENT_ID={{ openwhistle_oidc_client_id }}
OIDC_CLIENT_SECRET={{ openwhistle_oidc_client_secret }}
OIDC_SERVER_METADATA_URL={{ openwhistle_oidc_server_metadata_url }}
OIDC_REDIRECT_URI={{ openwhistle_oidc_redirect_uri }}

# ── LDAP ──────────────────────────────────────────────────────────────────────
LDAP_ENABLED={{ openwhistle_ldap_enabled }}
LDAP_SERVER={{ openwhistle_ldap_server }}
LDAP_PORT={{ openwhistle_ldap_port }}
LDAP_USE_SSL={{ openwhistle_ldap_use_ssl }}
LDAP_BIND_DN={{ openwhistle_ldap_bind_dn }}
LDAP_BIND_PASSWORD={{ openwhistle_ldap_bind_password }}
LDAP_BASE_DN={{ openwhistle_ldap_base_dn }}
LDAP_USER_FILTER={{ openwhistle_ldap_user_filter }}
LDAP_ATTR_USERNAME={{ openwhistle_ldap_attr_username }}
LDAP_ATTR_EMAIL={{ openwhistle_ldap_attr_email }}

# ── S3 storage ────────────────────────────────────────────────────────────────
STORAGE_BACKEND={{ openwhistle_storage_backend }}
S3_ENDPOINT_URL={{ openwhistle_s3_endpoint_url }}
S3_BUCKET_NAME={{ openwhistle_s3_bucket_name }}
S3_ACCESS_KEY_ID={{ openwhistle_s3_access_key_id }}
S3_SECRET_ACCESS_KEY={{ openwhistle_s3_secret_access_key }}
S3_REGION={{ openwhistle_s3_region }}
S3_PREFIX={{ openwhistle_s3_prefix }}

# ── SLA reminders ─────────────────────────────────────────────────────────────
REMINDER_ENABLED={{ openwhistle_reminder_enabled }}
REMINDER_ACK_WARN_DAYS={{ openwhistle_reminder_ack_warn_days }}
REMINDER_FEEDBACK_WARN_DAYS={{ openwhistle_reminder_feedback_warn_days }}

# ── Email notifications ───────────────────────────────────────────────────────
NOTIFY_EMAIL_ENABLED={{ openwhistle_notify_email_enabled }}
NOTIFY_EMAIL_TO={{ openwhistle_notify_email_to }}
NOTIFY_EMAIL_FROM={{ openwhistle_notify_email_from }}
NOTIFY_SMTP_HOST={{ openwhistle_notify_smtp_host }}
NOTIFY_SMTP_PORT={{ openwhistle_notify_smtp_port }}
NOTIFY_SMTP_USER={{ openwhistle_notify_smtp_user }}
NOTIFY_SMTP_PASSWORD={{ openwhistle_notify_smtp_password }}
NOTIFY_SMTP_TLS={{ openwhistle_notify_smtp_tls }}
NOTIFY_SMTP_SSL={{ openwhistle_notify_smtp_ssl }}

# ── Webhook notifications ─────────────────────────────────────────────────────
NOTIFY_WEBHOOK_ENABLED={{ openwhistle_notify_webhook_enabled }}
NOTIFY_WEBHOOK_URL={{ openwhistle_notify_webhook_url }}
NOTIFY_WEBHOOK_SECRET={{ openwhistle_notify_webhook_secret }}
NOTIFY_WEBHOOK_TYPE={{ openwhistle_notify_webhook_type }}
