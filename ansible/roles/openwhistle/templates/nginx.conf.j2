worker_processes auto;
error_log /dev/stderr warn;
pid /tmp/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Privacy: disable ALL access logging — never log IP addresses
    access_log off;
    log_not_found off;
    server_tokens off;

    # Flood protection for dynamic endpoints (submission channel especially).
    # Keys on the client IP only for in-memory throttling — the IP is NOT logged
    # or forwarded upstream (access_log is off; IP headers are stripped below),
    # so whistleblower anonymity is preserved while abusive bursts are limited.
    limit_req_zone $binary_remote_addr zone=ow_req:10m rate=10r/s;
    limit_req_status 429;

    upstream openwhistle {
        server app:4009;
        keepalive 32;
    }

{% if openwhistle_tls_enabled | bool %}
    # HTTP → HTTPS redirect
    server {
        listen 80;
        server_name {{ openwhistle_domain }};
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl http2;
        server_name {{ openwhistle_domain }};

        ssl_certificate     /etc/letsencrypt/live/{{ openwhistle_domain }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ openwhistle_domain }}/privkey.pem;
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers off;
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 1d;

        # Security headers (HSTS, X-Content-Type-Options, X-Frame-Options,
        # Referrer-Policy, CSP, …) are emitted by a single authoritative layer:
        # the application's SecurityMiddleware (app/middleware.py). They are
        # intentionally NOT set here — nginx `add_header` appends rather than
        # replaces upstream headers, so duplicating them produced conflicting,
        # unrecognised headers (GHSA-gh23-4h5j-cqj8).

        # Strip ALL IP-forwarding headers for whistleblower anonymity
        proxy_set_header X-Forwarded-For     "";
        proxy_set_header X-Real-IP           "";
        proxy_set_header Forwarded           "";
        proxy_set_header X-Client-IP         "";
        proxy_set_header X-Cluster-Client-IP "";
        proxy_set_header True-Client-IP      "";
        proxy_set_header CF-Connecting-IP    "";

        proxy_set_header Host              $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        location / {
            # Generous burst so the multi-step submission wizard and normal
            # admin use are unaffected; blocks rapid automated floods.
            limit_req zone=ow_req burst=30 nodelay;
            proxy_pass http://openwhistle;
            proxy_read_timeout 60s;
            proxy_connect_timeout 10s;
            proxy_send_timeout 60s;
        }

        location /static/ {
            proxy_pass http://openwhistle;
            expires 30d;
            add_header Cache-Control "public, immutable";
        }
    }
{% else %}
    server {
        listen 80;
        server_name {{ openwhistle_domain }};

        # Strip ALL IP-forwarding headers for whistleblower anonymity
        proxy_set_header X-Forwarded-For     "";
        proxy_set_header X-Real-IP           "";
        proxy_set_header Forwarded           "";
        proxy_set_header X-Client-IP         "";
        proxy_set_header X-Cluster-Client-IP "";
        proxy_set_header True-Client-IP      "";
        proxy_set_header CF-Connecting-IP    "";

        proxy_set_header Host              $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        location / {
            # Generous burst so the multi-step submission wizard and normal
            # admin use are unaffected; blocks rapid automated floods.
            limit_req zone=ow_req burst=30 nodelay;
            proxy_pass http://openwhistle;
            proxy_read_timeout 60s;
            proxy_connect_timeout 10s;
            proxy_send_timeout 60s;
        }

        location /static/ {
            proxy_pass http://openwhistle;
            expires 30d;
            add_header Cache-Control "public, immutable";
        }
    }
{% endif %}
}
